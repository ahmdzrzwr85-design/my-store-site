# Example environment variables (do NOT commit secrets)
# Set `DATABASE_URL` to your Postgres connection string.
# Generate a 32-byte base64 key for `ENCRYPTION_KEY`, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

DATABASE_URL=postgres://user:password@localhost:5432/ah_store
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
ALLOW_DECRYPT=false
